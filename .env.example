###############################################################################
# Planner Hospice - variabili d'ambiente
#
# Copiare in .env e personalizzare. NON committare .env in repo.
###############################################################################

# Ambiente: local | staging | production
APP_ENV=local

# Debug: 1 mostra errori dettagliati, 0 li nasconde (produzione SEMPRE 0)
APP_DEBUG=1

# URL base completo (senza slash finale). Esempio produzione:
# APP_URL=https://plannerhospice.example.org
APP_URL=http://localhost:8000

# Timezone PHP
APP_TIMEZONE=Europe/Rome

# Locale per formattazione date
APP_LOCALE=it_IT

# Chiave segreta per firma token (generare con: php -r "echo bin2hex(random_bytes(32));")
APP_KEY=

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=hospice_turni
DB_USER=hospice_user
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ----------------------------------------------------------------------------
# Sessione
# ----------------------------------------------------------------------------
# Durata sessione in secondi (default 2h)
SESSION_LIFETIME=7200

# Forza cookie Secure (HTTPS). Mettere 1 in produzione.
SESSION_SECURE=0

# Nome del cookie di sessione
SESSION_NAME=planner_hospice_session

# ----------------------------------------------------------------------------
# Autenticazione e lockout
# ----------------------------------------------------------------------------
AUTH_MIN_PASSWORD_LENGTH=10
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# ----------------------------------------------------------------------------
# Logging
# ----------------------------------------------------------------------------
# Livello: debug | info | notice | warning | error | critical
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Email (opzionale - per notifiche future)
# ----------------------------------------------------------------------------
MAIL_FROM_NAME="Planner Hospice"
MAIL_FROM_EMAIL=noreply@hospice.local
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
