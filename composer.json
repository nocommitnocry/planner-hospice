{
    "name": "hospice/planner-hospice",
    "description": "Gestione turni Hospice - pianificazione, saldi ore, conflitti, generatore automatico",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": "^8.2",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-intl": "*",
        "twig/twig": "^3.10",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.6",
        "phpoffice/phpspreadsheet": "^4.2",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html tests/coverage"
    }
}
