{% extends 'layout/base.twig' %}

{% block title %}
    {{ turno ? 'Modifica turno' : 'Assegna turno' }} &middot; {{ labelMese }} &middot; {{ app.name }}
{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <div>
                <a href="{{ url('/piani-turno/' ~ piano.id) }}" class="text-decoration-none small">&larr; Torna al piano</a>
                <h1 class="h3 mb-0">{{ turno ? 'Modifica turno' : 'Assegna turno' }}</h1>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body py-2">
                <div class="row small">
                    <div class="col-sm-6">
                        <span class="text-muted">Operatore:</span>
                        <strong>{{ operatore.cognome }} {{ operatore.nome }}</strong>
                    </div>
                    <div class="col-sm-6">
                        <span class="text-muted">Data:</span>
                        <strong>{{ labelData }}</strong>
                    </div>
                </div>
            </div>
        </div>

        {% if fuoriFinestra %}
            <div class="alert alert-danger small">
                <strong>Data fuori dal periodo di servizio.</strong>
                {{ fuoriFinestra }}
                {% if turno %}
                    Il turno esistente può essere modificato o eliminato, ma non se ne possono creare di nuovi in date fuori finestra.
                {% else %}
                    L'assegnazione di un nuovo turno verrà rifiutata.
                {% endif %}
            </div>
        {% endif %}

        {% if inAssenza %}
            {% if not turno %}
                {# Cella vuota in periodo di assenza: il nuovo turno verrà rifiutato. #}
                <div class="alert alert-danger small">
                    <strong>Operatore in assenza.</strong>
                    {{ inAssenza }}
                    L'assegnazione di un nuovo turno verrà rifiutata. Modifica il periodo di assenza in
                    <a href="{{ url('/assenze') }}">/assenze</a> se è sbagliato.
                </div>
            {% elseif assenzaRidondante %}
                {# Turno esistente di tipo assenza che coincide con l'assenza programmata.
                   Stato coerente ma ridondante: il consiglio è eliminare il turno (l'assenza
                   già copre il giorno). La modifica del tipo turno è bloccata server-side. #}
                <div class="alert alert-info small">
                    <strong>Turno ridondante con un'assenza programmata.</strong>
                    {{ inAssenza }} Il turno è già di tipo assenza coincidente: ti consigliamo di
                    eliminarlo (l'assenza già copre il giorno). La modifica del tipo turno non è
                    consentita: se serve cambiare, correggi prima il periodo dell'assenza.
                </div>
            {% else %}
                {# Turno esistente di lavoro in periodo di assenza: vero conflitto.
                   L'unica azione lecita è eliminare; la modifica del tipo è bloccata. #}
                <div class="alert alert-danger small">
                    <strong>Turno in conflitto con un'assenza.</strong>
                    {{ inAssenza }} L'unica azione consentita è l'eliminazione del turno. Per
                    modificarne il tipo, restringi prima il periodo dell'assenza in
                    <a href="{{ url('/assenze') }}">/assenze</a>.
                </div>
            {% endif %}
        {% endif %}

        {# Sessione 5-bis: warning vincoli leggibile (frase parlata invece di
           <code>no_notti</code>). Mappa di traduzione inline: il set e' chiuso
           e piccolo (3 codici). Se in futuro cresce, spostarla in un helper
           Twig globale o nel BaseController::commonViewData. #}
        {% if vincoli|length > 0 %}
            <div class="alert alert-warning small">
                <strong>L'operatore ha {{ vincoli|length > 1 ? 'vincoli attivi' : 'un vincolo attivo' }}:</strong>
                <ul class="mb-0">
                    {% for v in vincoli %}
                        <li>
                            {{ {
                                'no_notti':     'Non dovrebbe fare turni notturni',
                                'no_weekend':   'Non dovrebbe lavorare nei weekend (sabato/domenica)',
                                'solo_mattine': 'Preferenza forte per turni del mattino',
                            }[v.tipo_vincolo]|default('Vincolo: ' ~ v.tipo_vincolo) }}
                            {% if v.data_inizio or v.data_fine %}
                                ({{ v.data_inizio ? 'dal ' ~ format_date(v.data_inizio) : 'da sempre' }}{{ v.data_fine ? ' al ' ~ format_date(v.data_fine) : ', senza fine' }})
                            {% endif %}
                            {% if v.note %} — <span class="text-muted">{{ v.note }}</span>{% endif %}
                        </li>
                    {% endfor %}
                </ul>
                <div class="text-muted mt-1">
                    Non bloccante: procedi solo se esiste un accordo per copertura.
                </div>
            </div>
        {% endif %}

        {% set actionUrl = turno
            ? url('/piani-turno/' ~ piano.id ~ '/turni/' ~ turno.id)
            : url('/piani-turno/' ~ piano.id ~ '/turni') %}

        <form method="post" action="{{ actionUrl }}" novalidate>
            {{ csrf_field() }}
            {% if not turno %}
                <input type="hidden" name="id_operatore" value="{{ operatore.id }}">
                <input type="hidden" name="data" value="{{ data }}">
            {% endif %}

            <div class="mb-3">
                <label class="form-label">Tipo turno <span class="text-danger">*</span></label>
                {% set tipoSel = old_input.id_tipo_turno ?? (turno ? turno.id_tipo_turno : null) %}
                <div class="tipi-turno-grid {% if form_errors.id_tipo_turno %}is-invalid{% endif %}">
                    {% for t in tipi %}
                        <label class="tipo-turno-opzione {% if tipoSel == t.id %}selected{% endif %}"
                               style="background-color: {{ t.colore }};"
                               title="{{ t.descrizione }} ({{ t.ore_conteggiate }}h)">
                            <input type="radio" name="id_tipo_turno" value="{{ t.id }}"
                                   {% if tipoSel == t.id %}checked{% endif %} required>
                            <span class="codice">{{ t.codice }}</span>
                            <span class="descrizione small">{{ t.descrizione }}</span>
                        </label>
                    {% endfor %}
                </div>
                {% if form_errors.id_tipo_turno %}
                    <div class="invalid-feedback d-block">{{ form_errors.id_tipo_turno|first }}</div>
                {% endif %}
            </div>

            <div class="mb-3">
                <label for="note" class="form-label">
                    Note <span class="text-muted small">(opzionale)</span>
                </label>
                <textarea id="note" name="note" rows="2" maxlength="1000"
                          class="form-control{% if form_errors.note %} is-invalid{% endif %}"
                          placeholder="Eventuali annotazioni…">{{ old_input.note ?? (turno ? turno.note : '') }}</textarea>
                {% if form_errors.note %}
                    <div class="invalid-feedback">{{ form_errors.note|first }}</div>
                {% endif %}
            </div>

            <div class="d-flex justify-content-between gap-2 mt-4 flex-wrap">
                <div>
                    {% if turno %}
                        <button type="submit" form="form-delete-turno" class="btn btn-outline-danger">Elimina turno</button>
                    {% endif %}
                </div>
                <div class="d-flex gap-2">
                    <a href="{{ url('/piani-turno/' ~ piano.id) }}" class="btn btn-outline-secondary">Annulla</a>
                    {# Disabilitato lato UI quando il submit fallirebbe comunque server-side:
                       - assenza che copre la data (block sia su store sia su update);
                       - data fuori finestra per un nuovo turno (block su store; update permesso). #}
                    {% set submitBloccato = inAssenza or (not turno and fuoriFinestra) %}
                    <button type="submit" class="btn btn-primary"{% if submitBloccato %} disabled{% endif %}>
                        {{ turno ? 'Salva modifiche' : 'Assegna turno' }}
                    </button>
                </div>
            </div>
        </form>

        {% if turno %}
            <form id="form-delete-turno" method="post"
                  action="{{ url('/piani-turno/' ~ piano.id ~ '/turni/' ~ turno.id ~ '/delete') }}"
                  onsubmit="return confirm('Eliminare questo turno? Il saldo dell\'operatore verrà ricalcolato.');"
                  class="d-none">
                {{ csrf_field() }}
            </form>
        {% endif %}
    </div>
</div>
{% endblock %}
