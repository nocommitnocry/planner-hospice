{% extends 'layout/base.twig' %}

{% block title %}Pagina non trovata &middot; {{ app.name }}{% endblock %}

{% block content %}
<div class="text-center py-5">
    <h1 class="display-1">404</h1>
    <p class="lead">Pagina non trovata.</p>
    <p class="text-muted">{{ message|default('La risorsa richiesta non esiste.') }}</p>
    <a href="{{ url('/') }}" class="btn btn-primary mt-3">Torna alla home</a>
</div>
{% endblock %}
