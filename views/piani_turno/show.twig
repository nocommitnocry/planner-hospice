{% extends 'layout/base.twig' %}

{% block title %}{{ labelMese }} &middot; Piani turno &middot; {{ app.name }}{% endblock %}

{% block main_class %}container-fluid py-4{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <a href="{{ url('/piani-turno') }}" class="text-decoration-none small">&larr; Tutti i piani</a>
        <h1 class="h3 mb-0">
            Piano turno — {{ labelMese }}
            <span class="badge bg-info text-dark align-middle">{{ piano.setting_nome }}</span>
            {% if piano.stato == 'bozza' %}
                <span class="badge bg-warning text-dark align-middle">bozza</span>
            {% elseif piano.stato == 'pubblicato' %}
                <span class="badge bg-success align-middle">pubblicato</span>
            {% else %}
                <span class="badge bg-secondary align-middle">archiviato</span>
            {% endif %}
        </h1>
        {% if piano.nome %}<div class="text-muted">{{ piano.nome }}</div>{% endif %}
    </div>

    {% if puoModificare %}
        <div class="d-flex gap-2 flex-wrap">
            {% if piano.stato == 'bozza' %}
                <form method="post" action="{{ url('/piani-turno/' ~ piano.id ~ '/publish') }}" class="d-inline"
                      onsubmit="return confirm('Pubblicare il piano? Sarà visibile come piano corrente.');">
                    {{ csrf_field() }}
                    <button type="submit" class="btn btn-success">Pubblica</button>
                </form>
                <a href="{{ url('/piani-turno/' ~ piano.id ~ '/delete-confirm') }}"
                   class="btn btn-outline-danger">Elimina…</a>
            {% elseif piano.stato == 'pubblicato' %}
                <form method="post" action="{{ url('/piani-turno/' ~ piano.id ~ '/unpublish') }}" class="d-inline"
                      onsubmit="return confirm('Riportare il piano in bozza per correggerlo?');">
                    {{ csrf_field() }}
                    <button type="submit" class="btn btn-outline-warning">Riporta in bozza</button>
                </form>
                <form method="post" action="{{ url('/piani-turno/' ~ piano.id ~ '/archive') }}" class="d-inline"
                      onsubmit="return confirm('Archiviare definitivamente il piano? L\'operazione non è reversibile.');">
                    {{ csrf_field() }}
                    <button type="submit" class="btn btn-outline-secondary">Archivia</button>
                </form>
            {% endif %}
        </div>
    {% endif %}
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted small mb-2">Periodo</h6>
                <div class="h5 mb-0">{{ labelMese }}</div>
                <div class="text-muted small">{{ giorni|length }} giorni</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted small mb-2">Turni assegnati</h6>
                <div class="h5 mb-0">{{ numTurni }}</div>
                <div class="text-muted small">
                    {% if numTurni == 0 %}
                        Nessun turno assegnato.{% if celleEditabili %} Clicca una cella per iniziare.{% endif %}
                    {% else %}
                        celle compilate
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted small mb-2">Operatori inclusi</h6>
                <div class="h5 mb-0">{{ saldi|length }}</div>
                <div class="text-muted small">con saldo ore</div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mt-4 mb-2">
    <h2 class="h5 mb-0">Calendario</h2>
    {% if celleEditabili %}
        <a href="{{ url('/piani-turno/' ~ piano.id ~ '/aggiungi-operatore') }}"
           class="btn btn-sm btn-outline-primary">+ Aggiungi operatore</a>
    {% endif %}
</div>
{% if not celleEditabili and puoModificare %}
    <div class="alert alert-light border small mb-2">
        Il piano è in stato <strong>{{ piano.stato }}</strong>: per modificare i turni riportalo prima in bozza.
    </div>
{% endif %}

<div class="table-responsive">
    <table class="table table-bordered table-sm calendario-piano mb-4">
        <thead>
            <tr>
                <th class="op-col">Operatore</th>
                {% for g in giorni %}
                    <th class="text-center {% if g.weekend %}weekend{% endif %}">
                        <div class="small text-muted">{{ g.nome }}</div>
                        <div>{{ g.numero }}</div>
                    </th>
                {% endfor %}
            </tr>
        </thead>
        <tbody>
            {% if saldi|length == 0 %}
                <tr>
                    <td colspan="{{ giorni|length + 1 }}" class="text-center text-muted">
                        Nessun operatore attivo al momento della creazione del piano.
                    </td>
                </tr>
            {% else %}
                {% for s in saldi %}
                    <tr>
                        <td class="op-col">
                            <strong>{{ s.operatore_cognome }}</strong> {{ s.operatore_nome }}
                            <div class="text-muted small">
                                {{ s.categoria_nome }}
                                {% if s.aggiunto_manualmente %}
                                    <span class="badge bg-info text-dark"
                                          title="Aggiunto manualmente in itinere{% if s.note_aggiunta %} — {{ s.note_aggiunta }}{% endif %}">
                                        in itinere · {{ s.setting_codice }}
                                    </span>
                                {% endif %}
                            </div>
                        </td>
                        {% for g in giorni %}
                            {% set turno = turniByOpData[s.id_operatore][g.date] ?? null %}
                            {% set cross = (not turno) ? (crossSettingByOpData[s.id_operatore][g.date] ?? null) : null %}
                            {% set primaAssunzione = s.operatore_data_assunzione and g.date < s.operatore_data_assunzione %}
                            {% set dopoCessazione  = s.operatore_data_cessazione and g.date > s.operatore_data_cessazione %}
                            {% set fuoriFinestra = (not turno) and (not cross) and (primaAssunzione or dopoCessazione) %}
                            {% set cellClass = 'text-center cella-turno' ~ (g.weekend ? ' weekend' : '') %}
                            {% if cross %}
                                {# Occupata in un altro piano dello stesso mese: overlay non cliccabile. #}
                                <td class="{{ cellClass }} cella-cross-setting"
                                    title="{{ cross.tipo_codice }} · {{ cross.tipo_descrizione }} — nel piano {{ cross.setting_nome }}{% if cross.note %} ({{ cross.note }}){% endif %}">
                                    <span class="cross-banda" style="background-color: {{ cross.tipo_colore }};" aria-hidden="true"></span>
                                    <span class="cross-codice">{{ cross.tipo_codice }}</span>
                                </td>
                            {% elseif fuoriFinestra %}
                                {# Fuori dal periodo di servizio dell'operatore: non assegnabile. #}
                                <td class="{{ cellClass }} cella-fuori-finestra"
                                    title="{% if primaAssunzione %}Operatore assunto solo dal {{ s.operatore_data_assunzione|date('d/m/Y') }}{% else %}Operatore cessato il {{ s.operatore_data_cessazione|date('d/m/Y') }}{% endif %}">
                                    <span aria-hidden="true">·</span>
                                </td>
                            {% elseif celleEditabili %}
                                <td class="{{ cellClass }} cella-editabile">
                                    <a class="cella-link"
                                       href="{{ url('/piani-turno/' ~ piano.id ~ '/turni/edit?operatore=' ~ s.id_operatore ~ '&data=' ~ g.date) }}"
                                       {% if turno %}
                                           style="background-color: {{ turno.tipo_colore }};"
                                           title="{{ turno.tipo_descrizione }}{% if turno.note %} — {{ turno.note }}{% endif %}"
                                       {% else %}
                                           title="Assegna turno a {{ s.operatore_cognome }} {{ s.operatore_nome }} il {{ g.numero }}"
                                       {% endif %}>
                                        {% if turno %}{{ turno.tipo_codice }}{% else %}<span class="cella-vuota">+</span>{% endif %}
                                    </a>
                                </td>
                            {% else %}
                                <td class="{{ cellClass }}"
                                    {% if turno %}
                                        style="background-color: {{ turno.tipo_colore }};"
                                        title="{{ turno.tipo_descrizione }}{% if turno.note %} — {{ turno.note }}{% endif %}"
                                    {% endif %}>
                                    {% if turno %}{{ turno.tipo_codice }}{% else %}&nbsp;{% endif %}
                                </td>
                            {% endif %}
                        {% endfor %}
                    </tr>
                {% endfor %}
            {% endif %}
        </tbody>
    </table>
</div>

<h2 class="h5 mt-4 mb-2">Saldi ore</h2>
<div class="table-responsive">
    <table class="table table-striped table-sm align-middle">
        <thead>
            <tr>
                <th>Operatore</th>
                <th>Categoria</th>
                <th class="text-end">Ore dovute</th>
                <th class="text-end">Ore lavorate</th>
                <th class="text-end">Saldo mese</th>
                <th class="text-end">Saldo progressivo</th>
                {% if celleEditabili %}<th class="text-end">Azioni</th>{% endif %}
            </tr>
        </thead>
        <tbody>
            {% for s in saldi %}
                <tr>
                    <td>
                        <strong>{{ s.operatore_cognome }}</strong> {{ s.operatore_nome }}
                        {% if s.aggiunto_manualmente %}
                            <span class="badge bg-info text-dark" title="{{ s.setting_nome }}">in itinere</span>
                        {% endif %}
                    </td>
                    <td>{{ s.categoria_nome }}</td>
                    <td class="text-end">{{ s.ore_dovute }}</td>
                    <td class="text-end">{{ s.ore_lavorate }}</td>
                    <td class="text-end {% if s.saldo_mese < 0 %}text-danger{% endif %}">{{ s.saldo_mese }}</td>
                    <td class="text-end {% if s.saldo_progressivo < 0 %}text-danger{% endif %}">{{ s.saldo_progressivo }}</td>
                    {% if celleEditabili %}
                        <td class="text-end text-nowrap">
                            <a href="{{ url('/piani-turno/' ~ piano.id ~ '/saldi/' ~ s.saldo_id ~ '/edit') }}"
                               class="btn btn-sm btn-outline-secondary">Modifica</a>
                            <form method="post"
                                  action="{{ url('/piani-turno/' ~ piano.id ~ '/operatori/' ~ s.id_operatore ~ '/rimuovi') }}"
                                  class="d-inline"
                                  onsubmit="return confirm('Rimuovere {{ s.operatore_cognome }} {{ s.operatore_nome }} dal piano? L\'operazione fallisce se ha turni assegnati.');">
                                {{ csrf_field() }}
                                <button type="submit" class="btn btn-sm btn-outline-danger">Rimuovi</button>
                            </form>
                        </td>
                    {% endif %}
                </tr>
            {% else %}
                <tr><td colspan="{{ celleEditabili ? 7 : 6 }}" class="text-center text-muted">Nessun saldo registrato.</td></tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<div class="text-muted small mt-3">
    Piano creato il {{ format_date(piano.creato_il, 'd/m/Y H:i') }}
    {% if piano.pubblicato_il %} &middot; pubblicato il {{ format_date(piano.pubblicato_il, 'd/m/Y H:i') }}{% endif %}
</div>
{% endblock %}
