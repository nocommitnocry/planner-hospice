{% extends 'layout/base.twig' %}

{% block title %}Conferma eliminazione piano &middot; {{ app.name }}{% endblock %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="mb-3">
            <a href="{{ url('/piani-turno/' ~ piano.id) }}" class="text-decoration-none small">&larr; Torna al piano</a>
        </div>

        <h1 class="h3 mb-3">Eliminare il piano «{{ labelMese }} — {{ piano.setting_nome }}»?</h1>

        <div class="alert alert-warning">
            <strong>Operazione irreversibile.</strong> Procedendo verranno cancellati permanentemente:
            <ul class="mb-0 mt-2">
                <li>la testata del piano (stato attuale: <strong>{{ piano.stato }}</strong>)</li>
                <li><strong>{{ numTurni }}</strong> turn{{ numTurni == 1 ? 'o' : 'i' }} già assegnat{{ numTurni == 1 ? 'o' : 'i' }} nel calendario</li>
                <li><strong>{{ numSaldi }}</strong> sald{{ numSaldi == 1 ? 'o' : 'i' }} ore di operatori «{{ piano.setting_nome }}» per {{ labelMese }}</li>
            </ul>
        </div>

        <p class="text-muted small">
            I saldi dell'altro piano dello stesso mese (se esistente) e i saldi dei mesi successivi
            non vengono toccati. Operazione disponibile perché il piano è in <strong>bozza</strong>:
            piani pubblicati o archiviati vanno prima riportati in bozza per essere eliminati.
        </p>

        <div class="card border-danger">
            <div class="card-body">
                <h5 class="card-title text-danger mb-3">Conferma eliminazione</h5>
                <form method="post" action="{{ url('/piani-turno/' ~ piano.id ~ '/delete') }}">
                    {{ csrf_field() }}
                    <div class="d-flex justify-content-end gap-2">
                        <a href="{{ url('/piani-turno/' ~ piano.id) }}" class="btn btn-outline-secondary">Annulla</a>
                        <button type="submit" class="btn btn-danger">Sì, elimina il piano</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
