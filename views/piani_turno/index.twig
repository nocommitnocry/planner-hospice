{% extends 'layout/base.twig' %}

{% block title %}Piani turno &middot; {{ app.name }}{% endblock %}

{% block content %}
{% set stato_qs = statoFiltro ? 'stato=' ~ statoFiltro : '' %}
{% set setting_qs = settingFiltro ? 'setting=' ~ settingFiltro : '' %}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Piani turno</h1>
    {% if currentUser.ruolo in ['admin', 'caposala'] %}
        <a href="{{ url('/piani-turno/create') }}" class="btn btn-primary">+ Nuovo piano</a>
    {% endif %}
</div>

<ul class="nav nav-pills mb-2">
    <li class="nav-item">
        <a class="nav-link {% if statoFiltro is null %}active{% endif %}"
           href="{{ url('/piani-turno' ~ (setting_qs ? '?' ~ setting_qs : '')) }}">Tutti gli stati</a>
    </li>
    {% for s in stati %}
        <li class="nav-item">
            <a class="nav-link {% if statoFiltro == s %}active{% endif %}"
               href="{{ url('/piani-turno?stato=' ~ s ~ (setting_qs ? '&' ~ setting_qs : '')) }}">{{ s|capitalize }}</a>
        </li>
    {% endfor %}
</ul>

<ul class="nav nav-pills mb-3">
    <li class="nav-item">
        <a class="nav-link {% if settingFiltro == '' %}active{% endif %}"
           href="{{ url('/piani-turno' ~ (stato_qs ? '?' ~ stato_qs : '')) }}">Tutti i setting</a>
    </li>
    {% for s in settings %}
        <li class="nav-item">
            <a class="nav-link {% if settingFiltro == s.codice %}active{% endif %}"
               href="{{ url('/piani-turno?' ~ (stato_qs ? stato_qs ~ '&' : '') ~ 'setting=' ~ s.codice) }}">
                {{ s.nome }}
            </a>
        </li>
    {% endfor %}
</ul>

{% if piani|length == 0 %}
    <div class="alert alert-info">
        {% if statoFiltro or settingFiltro %}
            Nessun piano corrisponde al filtro selezionato.
        {% else %}
            Nessun piano turno presente. {% if currentUser.ruolo in ['admin', 'caposala'] %}Crea il primo piano per iniziare a pianificare i turni.{% endif %}
        {% endif %}
    </div>
{% else %}
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Periodo</th>
                    <th>Setting</th>
                    <th>Nome</th>
                    <th class="text-center">Stato</th>
                    <th class="text-end">Turni</th>
                    <th>Creato da</th>
                    <th>Pubblicato il</th>
                    <th style="width:8rem" class="text-end">Azioni</th>
                </tr>
            </thead>
            <tbody>
                {% for p in piani %}
                    <tr>
                        <td>
                            <strong>{{ mesi[p.mese] }} {{ p.anno }}</strong>
                        </td>
                        <td><span class="badge bg-light text-dark border">{{ p.setting_nome }}</span></td>
                        <td class="text-muted">{{ p.nome|default('—') }}</td>
                        <td class="text-center">
                            {% if p.stato == 'bozza' %}
                                <span class="badge bg-warning text-dark">bozza</span>
                            {% elseif p.stato == 'pubblicato' %}
                                <span class="badge bg-success">pubblicato</span>
                            {% else %}
                                <span class="badge bg-secondary">archiviato</span>
                            {% endif %}
                        </td>
                        <td class="text-end">{{ p.num_turni }}</td>
                        <td class="small">
                            {% if p.creato_da_username %}
                                {{ p.creato_da_cognome }} {{ p.creato_da_nome }}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="small">
                            {{ p.pubblicato_il ? format_date(p.pubblicato_il, 'd/m/Y H:i') : '—' }}
                        </td>
                        <td class="text-end">
                            <a href="{{ url('/piani-turno/' ~ p.id) }}"
                               class="btn btn-sm btn-outline-primary">Apri</a>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
