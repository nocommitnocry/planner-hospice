{% extends 'layout/base.twig' %}

{% block title %}Assenze &middot; {{ app.name }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Assenze operatori</h1>
    <a href="{{ url('/assenze/create') }}" class="btn btn-primary">+ Nuova assenza</a>
</div>

<p class="text-muted small">
    Ferie, permessi, malattia e maternità. Le assenze con tipo turno marcato
    <em>esclude pianificazione</em> che coprono l'intero mese fanno sì che
    l'operatore non venga incluso nei piani creati per quel mese.
</p>

<ul class="nav nav-pills mb-3">
    <li class="nav-item">
        <a class="nav-link {% if settingFiltro == '' %}active{% endif %}"
           href="{{ url('/assenze') }}">Tutti i setting</a>
    </li>
    {% for s in settings %}
        <li class="nav-item">
            <a class="nav-link {% if settingFiltro == s.codice %}active{% endif %}"
               href="{{ url('/assenze?setting=' ~ s.codice) }}">{{ s.nome }}</a>
        </li>
    {% endfor %}
</ul>

{% if assenze|length == 0 %}
    <div class="alert alert-info">Nessuna assenza registrata in questo filtro.</div>
{% else %}
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>Operatore</th>
                    <th>Setting</th>
                    <th>Tipo</th>
                    <th>Dal</th>
                    <th>Al</th>
                    <th>Note</th>
                    <th>Inserita da</th>
                    <th class="text-end w-13r">Azioni</th>
                </tr>
            </thead>
            <tbody>
                {% for a in assenze %}
                    <tr>
                        <td><strong>{{ a.operatore_cognome }}</strong> {{ a.operatore_nome }}</td>
                        <td><span class="badge bg-light text-dark border">{{ a.setting_nome }}</span></td>
                        <td>
                            <span class="badge badge-tipo tt-bg-{{ a.id_tipo_turno }}">
                                {{ a.tipo_codice }}
                            </span>
                            <span class="text-muted small">{{ a.tipo_descrizione }}</span>
                            {% if a.tipo_esclude_pianificazione %}
                                <span class="badge bg-dark"
                                      title="Esclude l'operatore dal piano se copre l'intero mese">esclude pianif.</span>
                            {% endif %}
                        </td>
                        <td class="small">{{ a.data_inizio }}</td>
                        <td class="small">{{ a.data_fine }}</td>
                        <td class="small text-muted">{{ a.note|default('—') }}</td>
                        <td class="small text-muted">{{ a.creato_da_username|default('—') }}</td>
                        <td class="text-end">
                            <a href="{{ url('/assenze/' ~ a.id ~ '/edit') }}"
                               class="btn btn-sm btn-outline-secondary">Modifica</a>
                            <form method="post" action="{{ url('/assenze/' ~ a.id ~ '/delete') }}"
                                  class="d-inline"
                                  data-confirm="Eliminare l'assenza di {{ a.operatore_cognome }} {{ a.operatore_nome }} dal {{ a.data_inizio }} al {{ a.data_fine }}?">
                                {{ csrf_field() }}
                                <button type="submit" class="btn btn-sm btn-outline-danger">Elimina</button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
